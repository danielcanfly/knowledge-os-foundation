{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.local/schemas/provenance.schema.json",
  "title": "Knowledge OS Provenance Record",
  "description": "Claim-level lineage and access propagation for one knowledge subject.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_id", "subject", "created_at", "sources", "claims", "access", "integrity"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_id": {"type": "string", "pattern": "^prov_[0-9A-HJKMNP-TV-Z]{26}$"},
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "concept_id", "x_kos_id", "content_sha256"],
      "properties": {
        "kind": {"enum": ["concept", "section", "claim", "artifact"]},
        "concept_id": {"type": "string", "pattern": "^[^/].*[^.]$|^[A-Za-z0-9_-]+$"},
        "x_kos_id": {"type": "string", "pattern": "^ko_[0-9A-HJKMNP-TV-Z]{26}$"},
        "heading": {"type": "string", "minLength": 1},
        "content_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "created_at": {"$ref": "#/$defs/utcTimestamp"},
    "updated_at": {"$ref": "#/$defs/utcTimestamp"},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/source"}},
    "claims": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/claim"}},
    "access": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_audiences", "effective_audience", "policy_version", "declassified"],
      "properties": {
        "source_audiences": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/audience"}},
        "effective_audience": {"$ref": "#/$defs/audience"},
        "policy_version": {"const": "1.0"},
        "declassified": {"type": "boolean"},
        "declassification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["from", "to", "reviewer", "reason", "reviewed_at"],
          "properties": {
            "from": {"$ref": "#/$defs/audience"},
            "to": {"$ref": "#/$defs/audience"},
            "reviewer": {"type": "string", "minLength": 1},
            "reason": {"type": "string", "minLength": 20},
            "reviewed_at": {"$ref": "#/$defs/utcTimestamp"}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"declassified": {"const": true}}},
          "then": {"required": ["declassification"]},
          "else": {"not": {"required": ["declassification"]}}
        }
      ]
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_sha256", "generated_by", "run_id"],
      "properties": {
        "record_sha256": {"$ref": "#/$defs/sha256"},
        "generated_by": {"type": "string", "minLength": 1},
        "run_id": {"type": "string", "minLength": 1},
        "prompt_sha256": {"$ref": "#/$defs/sha256"},
        "model": {"type": "string", "minLength": 1}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "utcTimestamp": {"type": "string", "format": "date-time", "pattern": "Z$"},
    "audience": {"enum": ["public", "internal", "confidential", "restricted"]},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "page": {"type": "integer", "minimum": 1},
        "line_start": {"type": "integer", "minimum": 1},
        "line_end": {"type": "integer", "minimum": 1},
        "timestamp_start_ms": {"type": "integer", "minimum": 0},
        "timestamp_end_ms": {"type": "integer", "minimum": 0},
        "heading": {"type": "string", "minLength": 1},
        "selector": {"type": "string", "minLength": 1}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "uri", "kind", "content_sha256", "retrieved_at", "audience", "snapshot_key"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^src_[A-Za-z0-9_.:-]+$"},
        "uri": {"type": "string", "format": "uri"},
        "kind": {"enum": ["web", "pdf", "markdown", "git", "database", "api", "transcript", "manual", "dataset"]},
        "content_sha256": {"$ref": "#/$defs/sha256"},
        "retrieved_at": {"$ref": "#/$defs/utcTimestamp"},
        "audience": {"$ref": "#/$defs/audience"},
        "snapshot_key": {"type": "string", "minLength": 1, "not": {"pattern": "(?:^|/)\\.\\.(?:/|$)"}},
        "media_type": {"type": "string", "minLength": 3},
        "license": {"type": ["string", "null"]},
        "owner": {"type": ["string", "null"]}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "selector", "claim_sha256", "derivation_type", "confidence", "evidence", "review_status"],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^claim_[A-Za-z0-9_.:-]+$"},
        "selector": {"$ref": "#/$defs/locator"},
        "claim_sha256": {"$ref": "#/$defs/sha256"},
        "derivation_type": {"enum": ["quoted", "paraphrased", "synthesized", "inferred", "calculated", "manual"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_ref", "support", "locator"],
            "properties": {
              "source_ref": {"type": "string", "pattern": "^src_[A-Za-z0-9_.:-]+$"},
              "support": {"enum": ["supports", "contradicts", "context"]},
              "locator": {"$ref": "#/$defs/locator"},
              "quote_sha256": {"$ref": "#/$defs/sha256"}
            }
          }
        },
        "calculation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expression", "input_sha256", "output_sha256"],
          "properties": {
            "expression": {"type": "string", "minLength": 1},
            "input_sha256": {"$ref": "#/$defs/sha256"},
            "output_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "review_status": {"enum": ["unreviewed", "machine_checked", "human_approved", "rejected"]},
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reviewer", "reviewed_at"],
          "properties": {
            "reviewer": {"type": "string", "minLength": 1},
            "reviewed_at": {"$ref": "#/$defs/utcTimestamp"},
            "notes": {"type": "string"}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"derivation_type": {"const": "calculated"}}},
          "then": {"required": ["calculation"]}
        },
        {
          "if": {"properties": {"review_status": {"const": "human_approved"}}},
          "then": {"required": ["review"]}
        }
      ]
    }
  }
}
