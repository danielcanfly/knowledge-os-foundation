{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledge-os.invalid/schemas/tag-taxonomy-v0.1.schema.json",
  "title": "Knowledge OS Tag Taxonomy v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "taxonomy_id",
    "version",
    "status",
    "dimensions",
    "tag_aliases"
  ],
  "properties": {
    "schema_version": {
      "const": "knowledge-os-tag-taxonomy/v0.1"
    },
    "taxonomy_id": {
      "const": "daniel-knowledge-os/tag-taxonomy"
    },
    "version": {
      "type": "string",
      "pattern": "^0\\.1\\.[0-9]+$"
    },
    "status": {
      "enum": [
        "normative_draft",
        "active",
        "deprecated"
      ]
    },
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "concern",
        "lifecycle",
        "technique"
      ],
      "properties": {
        "domain": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
          }
        },
        "concern": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
          }
        },
        "lifecycle": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
          }
        },
        "technique": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
          }
        }
      }
    },
    "tag_aliases": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
      }
    }
  }
}
